  "keyFeatures": [
    "Preemptive, cooperative, and hybrid scheduling modes",
    "Multi-platform support: ARM, RISC-V, AVR, PIC, x86, MIPS, and more",
    "Memory protection unit (MPU) support for Cortex-M and ARM cores",
    "FreeRTOS+TCP: full IPv4/IPv6 TCP/IP networking stack",
    "coreMQTT: lightweight MQTT 3.1.1 client for AWS IoT connectivity",
    "coreHTTP: lightweight HTTP/1.1 client library",
    "corePKCS11: PKCS#11 interface for cryptographic operations",
    "AWS IoT Device Shadow, Defender, Jobs, and OTA update libraries",
    "FreeRTOS+CLI: extensible command-line interface for embedded systems",
    "FreeRTOS+Trace: runtime tracing and visualization support",
    "Cellular Interface library for LTE-M/NB-IoT connectivity",
    "Static and dynamic memory allocation support",
    "MIT licensed with long-term support (LTS) releases"
  ],
  "publicApiSurface": [
    "xTaskCreate() / xTaskCreateStatic()",
    "vTaskDelete()",
    "vTaskDelay() / vTaskDelayUntil()",
    "xQueueCreate() / xQueueSend() / xQueueReceive()",
    "xSemaphoreCreateBinary() / xSemaphoreGive() / xSemaphoreTake()",
    "xSemaphoreCreateMutex() / xSemaphoreCreateRecursiveMutex()",
    "xTimerCreate() / xTimerStart() / xTimerStop()",
    "xEventGroupCreate() / xEventGroupSetBits() / xEventGroupWaitBits()",
    "xStreamBufferCreate() / xStreamBufferSend() / xStreamBufferReceive()",
    "xMessageBufferCreate() / xMessageBufferSend() / xMessageBufferReceive()",
    "FreeRTOS_CLIRegisterCommand() / FreeRTOS_CLIProcessCommand()",
    "FreeRTOS_socket() / FreeRTOS_connect() / FreeRTOS_send() / FreeRTOS_recv()",
    "MQTT_Init() / MQTT_Connect() / MQTT_Publish() / MQTT_Subscribe()",
    "HTTPClient_Send() / HTTPClient_ReadHeader()"
  ]
